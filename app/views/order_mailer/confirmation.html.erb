<h1>Thanks for your order!</h1>
<p>Order #<%= @order.id %> — total: <%= number_to_currency(@order.total_cents / 100.0) %></p>
<ul>
  <% @order.line_items.each do |item| %>
    <li><%= item.product.name %> x<%= item.quantity %> — <%= number_to_currency(item.subtotal_cents / 100.0) %></li>
  <% end %>
</ul>
