<div class="row justify-content-center">
  <div class="col-md-6 col-lg-5">
    <div class="card card-body mb-3">
      <h2 class="mb-4">Editar conta</h2>

      <%= form_for(resource, as: resource_name, url: registration_path(resource_name), html: { method: :put }) do |f| %>
        <%= render "devise/shared/error_messages", resource: resource %>

        <div class="mb-3">
          <%= f.label :email, class: "form-label" %>
          <%= f.email_field :email, autofocus: true, autocomplete: "email", class: "form-control" %>
        </div>

        <% if devise_mapping.confirmable? && resource.pending_reconfirmation? %>
          <p class="text-muted small">Aguardando confirmação para: <%= resource.unconfirmed_email %></p>
        <% end %>

        <div class="mb-3">
          <%= f.label :password, class: "form-label" %>
          <small class="text-muted d-block">(deixe em branco se não quiser alterar)</small>
          <%= f.password_field :password, autocomplete: "new-password", class: "form-control" %>
          <% if @minimum_password_length %>
            <small class="text-muted"><%= @minimum_password_length %> caracteres no mínimo</small>
          <% end %>
        </div>

        <div class="mb-3">
          <%= f.label :password_confirmation, "Confirmação de senha", class: "form-label" %>
          <%= f.password_field :password_confirmation, autocomplete: "new-password", class: "form-control" %>
        </div>

        <div class="mb-3">
          <%= f.label :current_password, "Senha atual", class: "form-label" %>
          <small class="text-muted d-block">(necessária para confirmar as alterações)</small>
          <%= f.password_field :current_password, autocomplete: "current-password", class: "form-control" %>
        </div>

        <div class="actions">
          <%= f.submit "Atualizar", class: "btn btn-primary w-100" %>
        </div>
      <% end %>
    </div>

    <div class="card card-body">
      <h3 class="h6">Cancelar minha conta</h3>
      <%= button_to "Cancelar conta", registration_path(resource_name), data: { confirm: "Tem certeza?", turbo_confirm: "Tem certeza?" }, method: :delete, class: "btn btn-outline-danger btn-sm" %>
    </div>
  </div>
</div>
