<h1 class="mb-4">Shops</h1>

<% if @shops.empty? %>
  <p class="text-muted">No shops yet. <%= link_to "Sign up", new_user_registration_path %> and create one!</p>
<% else %>
  <div class="row">
    <% @shops.each do |shop| %>
      <div class="col-md-4 mb-3">
        <div class="card">
          <div class="card-body">
            <h2 class="h5 card-title"><%= link_to shop.name, produtos_path(shop_slug: shop.slug) %></h2>
          </div>
        </div>
      </div>
    <% end %>
  </div>
<% end %>
