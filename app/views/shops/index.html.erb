<div class="mb-4">
  <h1 class="mb-1">Lojas</h1>
  <p class="text-muted">Explore o catálogo de cada loja e monte seu carrinho.</p>
</div>

<% if @shops.empty? %>
  <p class="text-muted">Nenhuma loja ainda. <%= link_to "Cadastre-se", new_user_registration_path, class: "link-brand" %> e crie a sua!</p>
<% else %>
  <div class="row g-3">
    <% @shops.each do |shop| %>
      <div class="col-md-4">
        <%= link_to produtos_path(shop_slug: shop.slug), class: "text-decoration-none text-reset" do %>
          <div class="card card-hover h-100">
            <div class="card-body">
              <h2 class="h5 card-title mb-1"><%= shop.name %></h2>
              <p class="card-text text-muted small mb-0">Ver catálogo →</p>
            </div>
          </div>
        <% end %>
      </div>
    <% end %>
  </div>
<% end %>
