<div class="mb-4">
  <h1 class="mb-1"><%= ActsAsTenant.current_tenant.name %></h1>
  <p class="text-muted">Painel administrativo</p>
</div>

<div class="row g-3">
  <div class="col-md-6">
    <div class="card card-hover h-100">
      <div class="card-body">
        <h2 class="h5 card-title">📦 Produtos</h2>
        <p class="card-text text-muted small">Gerencie o catálogo da sua loja.</p>
        <%= link_to "Gerenciar produtos", admin_products_path(shop_slug: params[:shop_slug]), class: "btn btn-sm btn-outline-primary" %>
      </div>
    </div>
  </div>

  <div class="col-md-6">
    <div class="card card-hover h-100">
      <div class="card-body">
        <h2 class="h5 card-title">🧾 Pedidos</h2>
        <p class="card-text text-muted small">Acompanhe os pedidos recebidos.</p>
        <%= link_to "Ver pedidos", admin_orders_path(shop_slug: params[:shop_slug]), class: "btn btn-sm btn-outline-primary" %>
      </div>
    </div>
  </div>
</div>
