<%= link_to "← Voltar aos pedidos", admin_orders_path(shop_slug: params[:shop_slug]), class: "link-brand d-inline-block mb-3" %>

<div class="d-flex justify-content-between align-items-center mb-4">
  <h1 class="mb-0">Pedido #<%= @order.id %></h1>
  <span class="badge text-bg-info text-uppercase fs-6"><%= @order.status %></span>
</div>

<div class="card">
  <table class="table table-hover align-middle mb-0">
    <thead>
      <tr>
        <th>Produto</th>
        <th class="text-center">Quantidade</th>
        <th class="text-end">Subtotal</th>
      </tr>
    </thead>
    <tbody>
      <% @order.line_items.each do |item| %>
        <tr>
          <td><%= item.product.name %></td>
          <td class="text-center"><%= item.quantity %></td>
          <td class="text-end"><%= number_to_currency(item.subtotal_cents / 100.0) %></td>
        </tr>
      <% end %>
    </tbody>
  </table>
</div>

<p class="fs-5 fw-bold mt-3">Total: <%= number_to_currency(@order.total_cents / 100.0) %></p>
