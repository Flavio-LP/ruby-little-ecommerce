<h1 class="mb-4">Order #<%= @order.id %></h1>

<p>Status: <%= @order.status %></p>

<table class="table">
  <thead>
    <tr>
      <th>Product</th>
      <th>Quantity</th>
      <th>Subtotal</th>
    </tr>
  </thead>
  <tbody>
    <% @order.line_items.each do |item| %>
      <tr>
        <td><%= item.product.name %></td>
        <td><%= item.quantity %></td>
        <td><%= number_to_currency(item.subtotal_cents / 100.0) %></td>
      </tr>
    <% end %>
  </tbody>
</table>

<p class="fw-bold">Total: <%= number_to_currency(@order.total_cents / 100.0) %></p>
