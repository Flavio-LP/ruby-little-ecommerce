<% if cart.cart_items.empty? %>
  <div class="card card-body text-center text-muted py-5">
    Your cart is empty.
  </div>
<% else %>
  <div class="card">
    <table class="table table-hover align-middle mb-0">
      <thead>
        <tr>
          <th>Produto</th>
          <th class="text-center">Quantidade</th>
          <th class="text-end">Subtotal</th>
          <th></th>
        </tr>
      </thead>
      <tbody>
        <% cart.cart_items.each do |item| %>
          <tr>
            <td><%= item.product.name %></td>
            <td style="width: 100px;">
              <%= form_with model: item, url: cart_cart_item_path(shop_slug: params[:shop_slug], id: item.id), method: :patch, data: { turbo_stream: true } do |f| %>
                <%= f.number_field :quantity, value: item.quantity, min: 0, class: "form-control form-control-sm text-center", onchange: "this.form.requestSubmit()" %>
              <% end %>
            </td>
            <td class="text-end"><%= number_to_currency(item.subtotal_cents / 100.0) %></td>
            <td class="text-end">
              <%= button_to "Remover", cart_cart_item_path(shop_slug: params[:shop_slug], id: item.id), method: :delete, form: { data: { turbo_stream: true } }, class: "btn btn-link btn-sm text-danger p-0" %>
            </td>
          </tr>
        <% end %>
      </tbody>
    </table>
  </div>

  <div class="d-flex justify-content-between align-items-center mt-3">
    <p class="fs-5 fw-bold mb-0">Total: <%= number_to_currency(cart.total_cents / 100.0) %></p>
    <%= button_to "Checkout", checkout_path(shop_slug: params[:shop_slug]), class: "btn btn-success" %>
  </div>
<% end %>
