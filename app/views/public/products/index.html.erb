<div class="mb-4">
  <h1 class="mb-1"><%= ActsAsTenant.current_tenant.name %></h1>
  <p class="text-muted">Catálogo de produtos</p>
</div>

<% if @products.empty? %>
  <p class="text-muted">Esta loja ainda não tem produtos.</p>
<% else %>
  <div class="row g-3">
    <% @products.each do |product| %>
      <div class="col-md-4">
        <div class="card card-hover h-100">
          <div class="card-body d-flex flex-column">
            <h2 class="h5 card-title">
              <%= link_to product.name, produto_path(shop_slug: params[:shop_slug], id: product.id), class: "link-brand" %>
            </h2>
            <p class="card-text fs-5 fw-bold text-success mt-auto mb-2"><%= number_to_currency(product.price_cents / 100.0) %></p>
            <%= button_to "Add to cart", add_to_cart_produto_path(shop_slug: params[:shop_slug], id: product.id), form: { data: { turbo_stream: true } }, class: "btn btn-primary btn-sm w-100" %>
          </div>
        </div>
      </div>
    <% end %>
  </div>
<% end %>
